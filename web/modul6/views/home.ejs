<%
    title = "Home";
    pageTitle = "Dashboard Produk";
    body = `
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <div class="text-muted small">TOTAL PRODUK</div>
                    <div class="fs-3 fw-bold" id="statTotal">-</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <div class="text-muted small">KATEGORI</div>
                    <div class="fs-3 fw-bold" id="statKategori">-</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <div class="text-muted small">TOTAL ASET</div>
                    <div class="fs-3 fw-bold" id="statNilai">-</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header">Produk Terbaru</div>
        <table class="table mb-0">
            <thead>
                <tr><th>No</th><th>Nama Produk</th><th>Kategori</th><th>Harga</th></tr>
            </thead>
            <tbody id="bodyHome"></tbody>
        </table>
    </div>

    <div class="d-flex gap-2">
        <a href="/tambah" class="btn btn-primary">+ Tambah Produk</a>
        <a href="/produk" class="btn btn-outline-secondary">Lihat Semua Produk</a>
    </div>
    `;
%>
<%- include('layout') %>
