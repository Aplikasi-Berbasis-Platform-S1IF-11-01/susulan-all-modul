<%- include('partials/header') %>
<%- include('partials/navbar', { hasLogo: true }) %>

<div class="page-header">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-md-8">
        <h1>Daftar Barang Gudang</h1>
        <p>Lihat, cari, edit, atau hapus barang di gudang dengan cepat menggunakan fitur DataTable.</p>
      </div>
      <div class="col-md-4 text-md-end mt-3 mt-md-0">
        <a href="/form" class="btn btn-earth-primary">
          <i class="fa-solid fa-plus me-1"></i> Tambah Barang
        </a>
      </div>
    </div>
  </div>
</div>

<div class="container mb-5">
  <div class="row">
    <div class="col-12">
      <div class="card card-earth">
        <div class="card-earth-header d-flex justify-content-between align-items-center">
          <span><i class="fa-solid fa-table-list me-2"></i>Tabel Inventaris</span>
          <button id="btnRefreshTable" class="btn btn-sm btn-earth-secondary py-1 px-2">
            <i class="fa-solid fa-rotate me-1"></i> Refresh Data
          </button>
        </div>
        <div class="card-body p-0">
          <div class="table-earth-container">
            <table id="inventoryTable" class="table table-earth table-hover responsive nowrap" style="width:100%">
              <thead>
                <tr>
                  <th>Nama Barang</th>
                  <th>Kategori</th>
                  <th>Jumlah</th>
                  <th>Kondisi</th>
                  <th>Lokasi</th>
                  <th>Tanggal Ditambahkan</th>
                  <th class="all">Aksi</th>
                </tr>
              </thead>
              <tbody>
                <!-- Data will be loaded via AJAX from JSON source -->
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modal Detail Barang -->
<div class="modal fade" id="detailModal" tabindex="-1" aria-labelledby="detailModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0" style="border-radius: 16px; overflow: hidden; box-shadow: var(--shadow-lg);">
      <div class="modal-header text-white" style="background-color: var(--primary-earth);">
        <h5 class="modal-title" id="detailModalLabel"><i class="fa-solid fa-box-open me-2"></i>Detail Barang</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4" style="background-color: var(--bg-cream);">
        <div class="text-center mb-4">
          <span class="d-inline-block p-3 bg-white rounded-circle shadow-sm mb-2" style="border: 2px solid var(--border-color);">
            <i class="fa-solid fa-cubes fa-2x" style="color: var(--primary-earth);"></i>
          </span>
          <h4 id="detailName" class="fw-bold mb-1 text-dark">-</h4>
          <span id="detailCategory" class="badge bg-secondary mb-2">-</span>
        </div>
        
        <div class="card border-0 shadow-sm p-3 bg-white mb-3" style="border-radius: 12px;">
          <div class="row g-3">
            <div class="col-6">
              <small class="text-muted d-block">Jumlah / Stok</small>
              <strong id="detailQuantity" class="fs-5 text-dark">-</strong>
            </div>
            <div class="col-6">
              <small class="text-muted d-block">Kondisi</small>
              <div id="detailCondition" class="mt-1">-</div>
            </div>
            <div class="col-12">
              <hr class="my-1" style="border-color: var(--border-color);">
            </div>
            <div class="col-6">
              <small class="text-muted d-block">Lokasi Penyimpanan</small>
              <strong id="detailLocation" class="text-dark">-</strong>
            </div>
            <div class="col-6">
              <small class="text-muted d-block">Tanggal Ditambahkan</small>
              <strong id="detailCreatedAt" class="text-dark">-</strong>
            </div>
          </div>
        </div>

        <div class="card border-0 shadow-sm p-3 bg-white" style="border-radius: 12px;">
          <small class="text-muted d-block mb-1">Catatan Tambahan</small>
          <p id="detailNotes" class="mb-0 text-dark" style="font-style: italic; font-size: 0.95rem;">-</p>
        </div>
      </div>
      <div class="modal-footer border-0 bg-white d-flex justify-content-between">
        <button type="button" class="btn btn-earth-secondary" data-bs-dismiss="modal">Tutup</button>
        <div>
          <button id="btnEditDetail" class="btn btn-earth-primary me-2">
            <i class="fa-solid fa-pen-to-square me-1"></i> Edit
          </button>
          <button id="btnDeleteDetail" class="btn btn-danger rounded-3" style="background-color: var(--danger-color); border-color: var(--danger-color);">
            <i class="fa-solid fa-trash me-1"></i> Hapus
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
